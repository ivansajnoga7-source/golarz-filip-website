{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/api/admin" },
    { "source": "/admin.html", "destination": "/api/admin" }
  ],
  "routes": [
    { "src": "^/admin(?:\\.html)?$", "dest": "/api/admin" },
    { "handle": "filesystem" },
    { "src": "^/(.*)$", "dest": "/$1" }
  ],
  "redirects": [
    { "source": "/admin", "destination": "/api/admin", "permanent": false },
    { "source": "/admin.html", "destination": "/api/admin", "permanent": false }
  ]
}
