{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/admin", "destination": "/api/admin" },
    { "source": "/admin.html", "destination": "/api/admin" }
  ],
  "routes": [
    { "src": "^/admin(?:\\.html)?$", "dest": "/api/admin" },
    { "handle": "filesystem" },
    { "src": "^/(.*)$", "dest": "/$1" }
  ],
  "redirects": [
    { "source": "/admin", "destination": "/api/admin", "permanent": false },
    { "source": "/admin.html", "destination": "/api/admin", "permanent": false }
  ]
}
